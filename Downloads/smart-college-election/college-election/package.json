{
  "name": "college-election-app",
  "type": "module",
  "version": "1.0.0",
  "description": "A modern, full-stack college election voting application built with React and TypeScript",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "cd src/frontend && npm run dev",
    "build": "cd src/frontend && npm run build",
    "typecheck": "cd src/frontend && npm run typecheck",
    "check": "cd src/frontend && npm run check",
    "fix": "cd src/frontend && npm run fix",
    "install-deps": "cd src/frontend && npm install",
    "seed:firestore": "node seed.js"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "firebase": "^12.15.0"
  }
}
